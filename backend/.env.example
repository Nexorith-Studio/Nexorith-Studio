PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/nexorith
FRONTEND_ORIGIN=http://nexorith.tech
JWT_SECRET=change-this-to-a-long-random-string
ADMIN_EMAIL=admin@nexorith.io
# Generate with: npm run hash-password -- "your-password"
ADMIN_PASSWORD_HASH=$2b$12$V3aA/NcP.fW5qGRkrOuVB.40GFepKeUq5VbMiyD3PH7ZQf3IBUWfK

# ─── Email / SMTP ───────────────────────────────────────────────────────────────
# For Gmail: use smtp.gmail.com + port 587 + an App Password (not your real password)
# For Resend: use smtp.resend.com + port 465 + your Resend API key as SMTP_PASS
# Leave blank to disable emails (they will be silently skipped)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
EMAIL_FROM="Nexorith Studio" <noreply@nexorith.tech>
